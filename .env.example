# Copy to .env.local and fill in from Clerk + Convex dashboards.
# Never commit .env.local.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Dashboard → API Keys → Frontend API URL (issuer). Convex reads this for auth.config.ts.
# Clerk Convex integration may label it CLERK_FRONTEND_API_URL; either name works in this project.
CLERK_FRONTEND_API_URL=https://your-instance.clerk.accounts.dev
# CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# From `npx convex dev` after linking a deployment
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
